        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List F1 sessions",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.openf1.org/v1/sessions",
            "params": [
              {
                "name": "session_key",
                "value": "",
                "type": "query"
              },
              {
                "name": "meeting_key",
                "value": "",
                "type": "query"
              },
              {
                "name": "year",
